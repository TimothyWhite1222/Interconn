@model LoginVM

@{
	Layout = null;
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登入 - Interconn</title>

    <link rel="stylesheet" href="~/css/Login.css" asp-append-version="true" />
</head>

<body class="login-body">

    <div class="login-container">
        <!-- 登入卡片 -->
        <div class="login-card">

            <!-- 品牌 Logo -->
            <div class="login-brand">
                Inter<span class="text-blue">conn</span>
            </div>

            <h1 class="login-title">歡迎回來</h1>
            <p class="login-subtitle">請輸入您的電子郵件與密碼以登入系統</p>

            <!-- 系統提示訊息 (如：註冊成功請登入) -->
            @if (TempData["Message"] != null)
            {
                <div class="alert-message">
                    @TempData["Message"]
                </div>
            }

            <form asp-action="Login" method="post" class="login-form">
                @Html.AntiForgeryToken()

                <!-- 全域錯誤訊息 (如帳號密碼錯誤) -->
                <div asp-validation-summary="ModelOnly" class="text-danger error-summary"></div>

                <!-- 電子郵件 -->
                <div class="form-group">
                    <label asp-for="Email" class="form-label">電子郵件</label>
                    <input asp-for="Email" class="form-input" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-danger error-text"></span>
                </div>

                <!-- 密碼 -->
                <div class="form-group">
                    <div class="label-row">
                        <label asp-for="Password" class="form-label">密碼</label>
                        <!-- 將忘記密碼移到密碼欄位右上方，這是目前最流行的 UX 設計 -->
                        <a asp-controller="PasswordReset" asp-action="PasswordReset" class="link-muted">忘記密碼？</a>
                    </div>
                    <input asp-for="Password" type="password" class="form-input" placeholder="••••••••••" />
                    <span asp-validation-for="Password" class="text-danger error-text"></span>
                </div>

                <!-- 登入按鈕 -->
                <button type="submit" class="btn-primary btn-block">登入</button>
            </form>

            <!-- 底部註冊連結 -->
            <div class="login-footer">
                還沒有帳號嗎？ <a asp-controller="Register" asp-action="Register" class="link-primary">立即註冊</a>
            </div>

        </div>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>