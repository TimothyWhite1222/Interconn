<!DOCTYPE html>
<html lang="zh-Hant">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - Interconn </title>


	<!-- 引入_Layout的css檔案 -->
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

	<!-- 引入Render的css檔案 -->
	@await RenderSectionAsync("Styles", required: false)
</head>
<body>
	<div class="app-layout">
		<!-- ================== 左側邊欄 (Sidebar) ================== -->
		<aside class="sidebar">
			<!-- 品牌 LOGO (字體完美置中) -->
			<div class="sidebar-brand">
				<a href="~/">Inter<span class="text-blue">conn</span></a>
			</div>

			<!-- 側邊欄選單 -->
			<nav class="sidebar-nav">
				<ul class="sidebar-menu">
					<li>
						<a class="sidebar-link" asp-controller="Home" asp-action="Index"> Home </a>
					</li>

					<li>
						<a class="sidebar-link" asp-controller="Members" asp-action="Index"> CRUD system </a>
					</li>

					<li>
						<a class="sidebar-link" asp-controller="Home" asp-action="Chat"> Chat Room </a>
					</li>

					<!-- 登出 (放在最底) -->
					<li style="margin-top:auto;">
						<form asp-controller="Login" asp-action="Logout" method="post">
							@Html.AntiForgeryToken()

							<button type="submit" class="sidebar-link" style="width:100%; text-align:left;">
								登出
							</button>
						</form>
					</li>

				</ul>
			</nav>
		</aside>

		<!-- ================== 右側主要內容區 ================== -->
		<div class="main-content">
			<!-- 頂部標題列 (Header) -->
			<header class="top-header">
				<div class="header-title">@ViewData["Title"]</div>
				<div class="header-user">
					<span class="user-avatar"></span>
					<span class="user-name">@User.Identity.Name</span>
				</div>
			</header>

			<!-- 渲染主內容的卡片區塊 -->
			<main class="content-wrapper">
				<div class="content-card">
					@RenderBody()
				</div>
			</main>

			<!-- 頁尾 -->
			<footer class="site-footer">
				<p>&copy; @DateTime.Now.Year - Interconn. All rights reserved.</p>
			</footer>
		</div>
	</div>

	<!-- 引入獨立的 JS 檔案 -->
	<script src="~/js/site.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>