@model Interconn.Models.Member

@section Styles {
    <!-- 只有進入這個頁面時css才會被載入 -->
    <link rel="stylesheet" href="~/css/MembersDelete.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "刪除會員";
}

<!-- 頁面標題區塊 -->
<div class="page-header">
    <h1 class="page-title">刪除會員</h1>
    <p class="text-muted">請確認是否要永久刪除此會員資料</p>
</div>

<!-- 危險操作警告橫幅 -->
<div class="danger-alert">
    <strong>⚠️ 警告：</strong> 您即將刪除這筆會員資料，此操作一旦執行將無法復原，請仔細確認!!!
</div>

<!-- 現代化卡片式版面 (沿用明細頁的結構來做最後確認) -->
<div class="delete-card">

    <!-- ================== 左側：個人簡介側邊欄 ================== -->
    <div class="profile-sidebar">
        <div class="avatar-wrapper">
            @if (!string.IsNullOrEmpty(Model.AvatarPath))
            {
                <img src="@Url.Content(Model.AvatarPath)" class="profile-avatar" alt="User Avatar" />
            }
            else
            {
                <img src="@Url.Content("~/images/members/default.png")" class="profile-avatar" alt="Default Avatar" />
            }
        </div>

        <h2 class="profile-name">@Html.DisplayFor(model => model.Name)</h2>
        <div class="profile-badge">
            @Html.DisplayFor(model => model.Gender)
        </div>
    </div>

    <!-- ================== 右側：詳細資料與確認表單 ================== -->
    <div class="profile-content">
        <h3 class="section-title">即將刪除的資料核對</h3>
        <hr class="divider" />

        <!-- 資料核對網格 -->
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">@Html.DisplayNameFor(model => model.BirthDate)</span>
                <span class="info-value">@Html.DisplayFor(model => model.BirthDate)</span>
            </div>

            <div class="info-item">
                <span class="info-label">@Html.DisplayNameFor(model => model.UpdatedTime)</span>
                <span class="info-value">@Html.DisplayFor(model => model.UpdatedTime)</span>
            </div>

            <div class="info-item full-width">
                <span class="info-label">@Html.DisplayNameFor(model => model.Bio)</span>
                <div class="info-value bio-box">
                    @if (string.IsNullOrEmpty(Model.Bio))
                    {
                        <span class="text-muted">該會員尚未填寫自我介紹。</span>
                    }
                    else
                    {
                        @Html.DisplayFor(model => model.Bio)
                    }
                </div>
            </div>
        </div>

        <!-- 底部操作按鈕 (包含防偽標籤與刪除表單) -->
        <form asp-action="Delete" class="action-bar">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="MemberId" />

            <a asp-action="Index" class="btn btn-secondary">取消並返回</a>
            <button type="submit" class="btn btn-danger">確認永久刪除</button>
        </form>
    </div>
</div>