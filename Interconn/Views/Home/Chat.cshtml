@section Styles {
	<!-- 只有進入這個頁面時css才會被載入 -->
	<link rel="stylesheet" href="~/css/Chat.css" asp-append-version="true" />
}

@{
	ViewData["Title"] = "聊天室";
}

<!-- 頁面標題區塊 -->
<div class="page-header">
	<h1 class="page-title">聊天室</h1>
	<p class="text-muted">與其他在線使用者進行即時交流</p>
</div>

<!-- 現代化聊天室版面 -->
<div class="chat-layout">

	<!-- ================== 左側：主要聊天區 ================== -->
	<div class="chat-main">
		<!-- 訊息顯示區 -->
		<div class="chat-messages" id="messages">
			<!-- JavaScript 會在這裡塞入訊息泡泡 -->
		</div>

		<!-- 下方輸入區 -->
		<div class="chat-input-area">
			<input type="text" id="msg" class="chat-input" placeholder="輸入你想說的話..." autocomplete="off" />
			<button class="btn-send" onclick="send()">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
				送出
			</button>
		</div>
	</div>

	<!-- ================== 右側：在線使用者 ================== -->
	<div class="chat-sidebar">
		<h5 class="sidebar-title">
			在線使用者
			<span class="online-count" id="online-count">
				<!-- JavaScript 會在這裡塞入在線人數 -->
			</span>
		</h5>
		<hr class="divider" />
		<ul id="users" class="users-list">
			<!-- JavaScript 會在這裡塞入使用者清單 -->
		</ul>
	</div>

</div>


@section Scripts {
	<!-- 前端引入SignalR的JavaScript函式庫 -->
	<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
	<script>
		//建立一個SignalR前端連線物件
		const connection = new signalR.HubConnectionBuilder()
			.withUrl("/chathub")
			.build();

		//監聽ReceiveMessage事件 接收Hub廣播的訊息
		connection.on("ReceiveMessage", function(user, message, time){
			const container = document.getElementById("messages");
			const div = document.createElement("div");
			div.classList.add("message-item");
			div.innerHTML = `<b>${user}:</b> ${message} <small>(${time})</small>`;
			container.appendChild(div);
			container.scrollTop = container.scrollHeight;
		});

		//監聽UserList事件 更新使用者清單跟人數
		connection.on("UserList", function(users){
			const ul = document.getElementById("users");
			const countSpan = document.getElementById("online-count");

			ul.innerHTML = "";
			users.forEach(u => {
				const li = document.createElement("li");
				li.textContent = u;
				ul.appendChild(li);
			});

			countSpan.textContent = users.length;
		});

		//載入歷史訊息
		connection.on("LoadHistoryResult", function (messages) {
			const container = document.getElementById("messages");
			container.innerHTML = "";

			messages.forEach(m => {
				const div = document.createElement("div");
				div.classList.add("message-item");

				div.innerHTML = `
					<div>
						<span class="message-name">${m.userName}</span>
						<span class="message-date">(${formatTime(m.createdTime)})</span>
					</div>
					<div class="message-body">
						${m.message}
					</div>
				`;

				container.appendChild(div);
			});

			container.scrollTop = container.scrollHeight;
		});

		//前端JavaScript啟動SignalR連線
		connection.start()
			.then(() => {
				console.log("SignalR 連線成功");				
			})
			.catch(err => console.error(err));

		//input的onclick事件 發送訊息的方法
		function send() {
			const input = document.getElementById("msg");
			const message = input.value.trim();
			if (message === "") return;

			connection.invoke("SendMessage", message)
				.then(() => {
					console.log("訊息送出:", message);
					input.value = "";
				})
				.catch(err => console.error("送出失敗:", err));
		}

		//按Enter也可以觸發Send()
		document.getElementById("msg")
			.addEventListener("keydown", function(e){
				if(e.key === "Enter") {
					e.preventDefault();
					send();
				}
			});

		//把歷史訊息傳入的時間格式改成正常的字串
		//這邊要轉換的原因是SignalR會把SendAsync("LoadHistoryResult", messages)傳過來的時間變成JSON
		function formatTime(dateStr){
			const date = new Date(dateStr);
			return (date.getMonth() + 1).toString().padStart(2, '0') + "/" +
			       date.getDate().toString().padStart(2,'0') + " " +
				   date.toLocaleDateString("en-US", { weekday: "short" }) + " " +
				   date.getHours().toString().padStart(2,'0') + ":" +
				   date.getMinutes().toString().padStart(2,'0');
		}
	</script>
}